# Copy to .env and fill in your values.
# The Makefile and docker-compose.yml read these via ${VAR:-} expansion.
# E2E tests (pytest -m vastai / runpod / kaggle) load this file automatically.

# -------------------------------------------------------------------
# Vast.ai + AWS (required for make vastai-train and pytest -m vastai)
# Vast.ai key: cloud.vast.ai/account/
# -------------------------------------------------------------------
VAST_API_KEY=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Optional Vast.ai overrides (defaults shown):
# VASTAI_GPU_QUERY=num_gpus=1 gpu_name=RTX_3090 reliability>0.99
# VASTAI_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel
# VASTAI_DISK_GB=50

# -------------------------------------------------------------------
# RunPod (required for make runpod-train and pytest -m runpod)
# -------------------------------------------------------------------
RUNPOD_API_KEY=

# -------------------------------------------------------------------
# Kaggle remote training (required for make kaggle-train)
# Get your key at kaggle.com -> Settings -> API -> Create New Token
# -------------------------------------------------------------------
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# -------------------------------------------------------------------
# SSH remote training (optional alternative to Kaggle)
# -------------------------------------------------------------------
REMOTE_HOST=
REMOTE_USER=
REMOTE_KEY_PATH=
REMOTE_WORK_DIR=~/aipet

# -------------------------------------------------------------------
# Raspberry Pi deployment (make docker-deploy)
# -------------------------------------------------------------------
RPI_HOST=raspberrypi.local
RPI_USER=pi

# -------------------------------------------------------------------
# Temporal server (default works for make temporal-up local dev)
# -------------------------------------------------------------------
TEMPORAL_HOST=localhost:7233

# -------------------------------------------------------------------
# Google Colab remote training (required for make colab-train)
# 1. Create an OAuth 2.0 Desktop app client in GCP Console
# 2. Run: make google-auth GOOGLE_OAUTH_CLIENT_SECRETS=path/to/client_secrets.json
# 3. Token is saved to ~/.config/aipet/google_token.json automatically
# -------------------------------------------------------------------
# Optional: override default token path (~/.config/aipet/google_token.json)
GOOGLE_OAUTH_TOKEN_FILE=
# ID from the Drive folder URL: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=

# -------------------------------------------------------------------
# Inference API
# -------------------------------------------------------------------
MODEL_PATH=models/aipet.gguf
